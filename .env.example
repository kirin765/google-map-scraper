# Google Maps scraper runtime configuration.
GOOGLE_MAP_SCRAPER_REGION=Seoul, South Korea
GOOGLE_MAP_SCRAPER_KEYWORDS=cafe,restaurant,tourist attraction
GOOGLE_MAP_SCRAPER_OUTPUT_DIR=output
GOOGLE_MAP_SCRAPER_OUTPUT_FORMAT=ndjson
GOOGLE_MAP_SCRAPER_MAX_PLACES_PER_KEYWORD=25
GOOGLE_MAP_SCRAPER_MAX_REVIEWS_PER_PLACE=20
GOOGLE_MAP_SCRAPER_BROWSER_NAME=chromium
GOOGLE_MAP_SCRAPER_BROWSER_EXECUTABLE_PATH=
GOOGLE_MAP_SCRAPER_HEADLESS=true
GOOGLE_MAP_SCRAPER_LOCALE=ko-KR
GOOGLE_MAP_SCRAPER_USER_AGENT=Mozilla/5.0
GOOGLE_MAP_SCRAPER_PROXY=
GOOGLE_MAP_SCRAPER_TIMEOUT_MS=30000
GOOGLE_MAP_SCRAPER_RETRY_ATTEMPTS=3
GOOGLE_MAP_SCRAPER_RETRY_DELAY_MS=750
GOOGLE_MAP_SCRAPER_CHECKPOINT_PATH=
GOOGLE_MAP_SCRAPER_DEBUG=false
